# Stödkompassen AI chat (src/pages/api/chat.ts) — server-side only.
# Copy to .env for local dev; set these in the Render dashboard in production.

# Required: Anthropic API key. Read at runtime by the Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the chat model (defaults to claude-opus-4-8).
# STODKOMPASSEN_MODEL=claude-opus-4-8
