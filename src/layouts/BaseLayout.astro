---
import "../styles/tokens.css";
import "../styles/icons.css";
import "../styles/global.css";
import Launcher from "../components/stodkompassen/Launcher.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Hitta svenska stödlinjer för kris, ångest, våld, ensamhet och oro. Anonymt, kostnadsfritt och tillgängligt.",
} = Astro.props;

// The full chat already lives on /chatt/, so the floating launcher is shown
// everywhere else.
const showLauncher = !Astro.url.pathname.startsWith("/chatt");
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Type faces load from the jsdelivr CDN (GT Alpina via @font-face,
         Söhne / Söhne Mono via @import in global.css); preconnect so the
         woff2 requests start sooner. -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <script is:inline>
      // Set theme before paint to avoid a flash. Honour saved choice,
      // else the OS preference.
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const theme =
            saved ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        } catch (_) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Hoppa till innehåll</a>
    <slot />
    {showLauncher && <Launcher />}
    <style>
      /* Off-screen until a keyboard user tabs to it, then it drops into view
         at the top-left as the first focus stop. */
      .skip-link {
        position: fixed;
        top: var(--space-3);
        left: var(--space-3);
        z-index: 100;
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-pill);
        background: var(--accent);
        color: var(--accent-fg);
        font-size: 0.9375rem;
        font-weight: 500;
        transform: translateY(calc(-100% - var(--space-4)));
        transition: transform 0.15s ease;
      }
      .skip-link:focus-visible {
        transform: translateY(0);
      }
    </style>
  </body>
</html>
