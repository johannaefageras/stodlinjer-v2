---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import SupportLineDetail from "../../components/SupportLineDetail.astro";
import SiteFooter from "../../components/SiteFooter.astro";

// One static page per active support line — the deep-link / no-JS / SEO
// fallback behind the homepage modal. The card grid links here via
// `/stodlinjer/${slug}/`, so the same active-only set is mirrored.
export const getStaticPaths = (async () => {
  const lines = await getCollection("supportLines", (e) => e.data.status === "active");
  return lines.map((line) => ({ params: { slug: line.data.slug }, props: { line } }));
}) satisfies GetStaticPaths;

const { line } = Astro.props;
const d = line.data;
---

<BaseLayout title={`${d.name} | Stödlinjer`} description={d.shortDescription}>
  <header class="topbar">
    <div class="topbar__inner container--wide">
      <a class="brand" href="/">Stödlinjer</a>
      <ThemeToggle />
    </div>
  </header>

  <main id="main" class="page container">
    <a class="back" href="/#stodlinjer">
      <Icon name="thin-left-arrow" size={15} />
      Alla stödlinjer
    </a>

    <SupportLineDetail line={line} heading="h1" />
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* ── Topbar (slim) ──────────────────────────────────────── */
  .topbar {
    position: sticky;
    top: var(--acute-strip-h, 0); /* stack below the sticky AcuteStrip */
    z-index: 50;
    border-bottom: var(--hairline) solid var(--border);
    background: color-mix(in oklch, var(--background) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--foreground);
  }

  /* ── Page shell ─────────────────────────────────────────── */
  .page {
    padding-block: var(--space-8) var(--space-16);
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.90625rem;
    color: var(--muted);
    margin-bottom: var(--space-8);
    transition: color 0.15s ease;
  }
  .back:hover {
    color: var(--foreground);
  }
</style>
