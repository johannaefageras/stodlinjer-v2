---
import Mascot from "./Mascot.astro";

interface Props {
  /** "page" = full surface on /chatt/, "panel" = inside the launcher (adds close). */
  variant?: "page" | "panel";
}

const { variant = "page" } = Astro.props;

const greeting =
  "Hej, jag är Stödkompassen. Berätta gärna lite om hur du har det eller vad du behöver — så hjälper jag dig att hitta rätt stöd. Du kan vara helt anonym.";
---

<section class="sk" data-variant={variant} aria-label="Stödkompassen">
  <header class="sk__head">
    <span class="sk-avatar">
      <Mascot size={44} />
      <span class="sk-avatar__dot" aria-hidden="true"></span>
    </span>
    <div class="sk__heading">
      <div class="sk__title-row">
        <p class="sk__title">Stödkompassen</p>
        {
          variant === "panel" && (
            <button class="sk__close" type="button" data-sk-close aria-label="Stäng">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                <line x1="6" y1="6" x2="18" y2="18" />
                <line x1="18" y1="6" x2="6" y2="18" />
              </svg>
            </button>
          )
        }
      </div>
      <p class="sk__tagline">Du behöver inte veta vad du ska säga.</p>
    </div>
  </header>

  <div class="sk__log" data-sk-log aria-live="polite" aria-label="Konversation">
    <div class="sk__welcome">
      <img
        class="sk__welcome-art"
        src="/imgs/web/stodkompassen-waving.webp"
        width="168"
        height="224"
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
        data-sk-mascot
      />
      {/* Pick the mascot pose in the browser: a random daytime pose, or the
         sleeping pose at night (22:00–06:00 Europe/Stockholm, DST-safe). This
         can't be a build-time choice — the static build would bake in one pose
         and one moment in time. `is:inline` keeps the script unbundled so it
         runs synchronously, before the (lazy) default `waving` ever loads; that
         default is also the no-JS fallback. */}
      <script is:inline>
        (function () {
          var poses = [
            "hands-on-heart", "heart-hands", "holding-compass", "holding-heart",
            "neutral", "pointing", "thumbs-up", "victory", "waving", "welcoming",
          ];
          var hour = Number(
            new Intl.DateTimeFormat("sv-SE", {
              timeZone: "Europe/Stockholm",
              hour: "2-digit",
              hourCycle: "h23",
            }).format(new Date())
          );
          var pose =
            hour >= 22 || hour < 6
              ? "sleeping"
              : poses[Math.floor(Math.random() * poses.length)];
          var src = "/imgs/web/stodkompassen-" + pose + ".webp";
          document
            .querySelectorAll(".sk__welcome-art[data-sk-mascot]")
            .forEach(function (el) {
              el.src = src;
            });
        })();
      </script>
      <p class="sk__welcome-text">{greeting}</p>
    </div>
  </div>

  <div class="sk__footer">
    <form class="sk__composer" data-sk-form>
      <textarea
        class="sk__input"
        data-sk-input
        rows="1"
        placeholder="Ställ en fråga…"
        aria-label="Skriv ditt meddelande"></textarea>
      <button class="sk__send" type="submit" data-sk-send>Skicka</button>
    </form>
    <p class="sk__note">
      Vid akut fara, ring <a href="tel:112">112</a>. Skriv inte känslig information.
    </p>
  </div>
</section>

<style is:global>
  /* All Stödkompassen styles descend from .sk (or shared .sk-* classes) so this
     global block also reaches chat content created at runtime by chat.ts. */
  .sk {
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
    color: var(--foreground);
    background: var(--background);
  }

  /* ── Avatar / mascot (header + launcher button) ────────────── */
  .sk-avatar {
    position: relative;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .sk-avatar__dot {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--background);
  }
  .sk-mascot {
    display: block;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .sk__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: var(--hairline) solid var(--border);
    flex-shrink: 0;
  }
  .sk__heading {
    min-width: 0;
    flex: 1;
  }
  .sk__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .sk__title {
    font-family: var(--font-serif);
    font-size: 1.3125rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--foreground);
  }
  .sk__tagline {
    font-size: 0.9375rem;
    line-height: 1.35;
    color: var(--muted);
  }
  .sk__close {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    margin: -6px -4px -6px 0;
    border: none;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--subtle);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sk__close:hover {
    background: var(--hover);
    color: var(--foreground);
  }
  .sk__close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Message log ───────────────────────────────────────────── */
  .sk__log {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6) var(--space-4);
    scroll-behavior: smooth;
  }
  @media (prefers-reduced-motion: reduce) {
    .sk__log {
      scroll-behavior: auto;
    }
  }
  /* Centre the welcome (mascot + greeting) while the log is empty. Once the
     first message arrives the log reverts to top-aligned, scrollable flow.
     `safe center` falls back to top-alignment if the welcome ever exceeds the
     log height (very short screens), so its top can never be clipped. */
  .sk__log:not(:has(.sk-msg)) {
    justify-content: safe center;
  }

  /* ── Welcome state (mascot + greeting, before the first reply) ──── */
  .sk__welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding-block: var(--space-2) var(--space-2);
  }
  .sk__welcome-art {
    width: clamp(148px, 44%, 184px);
    height: auto;
  }
  .sk__welcome-text {
    max-width: 40ch;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }
  .sk[data-variant="panel"] .sk__welcome-art {
    width: 136px;
  }
  .sk[data-variant="panel"] .sk__welcome-text {
    font-size: 1rem;
  }

  .sk-msg--assistant {
    align-self: flex-start;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    max-width: 100%;
    width: 100%;
  }
  .sk-msg--user {
    align-self: flex-end;
    max-width: 85%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-card) var(--radius-card) 5px var(--radius-card);
    background: var(--accent);
    color: var(--accent-fg);
    font-size: 1.0625rem;
    line-height: 1.5;
  }
  .sk-msg--user p {
    margin: 0;
  }

  /* Soft lavender assistant bubble. */
  .sk-bubble {
    max-width: 92%;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-card) var(--radius-card) var(--radius-card) 5px;
    background: var(--accent-soft);
    color: var(--foreground);
    font-size: 1.0625rem;
    line-height: 1.55;
  }
  .sk-bubble p {
    margin: 0;
  }
  .sk-bubble p + p {
    margin-top: var(--space-3);
  }

  /* Typing indicator */
  .sk-dots {
    display: inline-flex;
    gap: 5px;
    padding: 3px 2px;
  }
  .sk-dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-soft-fg);
    animation: sk-bounce 1.2s infinite ease-in-out both;
  }
  .sk-dots span:nth-child(2) {
    animation-delay: 0.15s;
  }
  .sk-dots span:nth-child(3) {
    animation-delay: 0.3s;
  }
  @keyframes sk-bounce {
    0%, 80%, 100% {
      transform: scale(0.7);
      opacity: 0.5;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sk-dots span {
      animation: none;
    }
  }

  /* ── Recommended-line card ─────────────────────────────────── */
  .sk-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
  }
  .sk-card__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .sk-card__chip {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: var(--radius-chip, 11px);
    background: var(--c);
    color: var(--c-fg);
  }
  .sk-card__cat {
    font-size: 0.8125rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--subtle);
    font-weight: 500;
  }
  .sk-card__name {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--foreground);
    text-decoration: none;
  }
  .sk-card__name:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sk-card__desc {
    font-size: 0.96875rem;
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
  }
  .sk-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  .sk-card__value {
    font-size: 1.0625rem;
    color: var(--foreground);
    text-decoration: none;
  }
  a.sk-card__value:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sk-card__hours {
    font-size: 0.84375rem;
    color: var(--subtle);
  }

  /* Article suggestion: same shape as a line card, quieter surface so it reads
     as "something to read" rather than "someone to call right now". */
  .sk-card--article {
    background: var(--accent-soft);
  }
  .sk-card--article .sk-card__foot {
    border-top-color: color-mix(in oklch, var(--border) 60%, transparent);
  }

  /* Cards fade + rise in once, when first streamed into the conversation, so
     they feel placed rather than popped. Text bubbles grow in place (no
     animation). The class is added by chat.ts only on a card's first render. */
  .sk-card--enter {
    animation: sk-card-in 0.32s ease both;
  }
  @keyframes sk-card-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sk-card--enter {
      animation: none;
    }
  }

  /* ── Footer (composer · one quiet safety note) ─────────────── */
  .sk__footer {
    flex-shrink: 0;
    padding: var(--space-4);
    border-top: var(--hairline) solid var(--border);
  }
  .sk__composer {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
  }
  .sk__input {
    flex: 1;
    min-width: 0;
    resize: none;
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--foreground);
    font: inherit;
    font-size: 1.0625rem;
    line-height: 1.5;
    padding: 11px var(--space-4);
    max-height: 140px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .sk__input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in oklch, var(--accent) 22%, transparent);
  }
  .sk__input::placeholder {
    color: var(--subtle);
  }
  .sk__send {
    flex-shrink: 0;
    border: none;
    border-radius: var(--radius-lg);
    background: var(--accent);
    color: var(--accent-fg);
    font-size: 1rem;
    font-weight: 500;
    padding: 12px var(--space-6);
    cursor: pointer;
    transition: background 0.15s ease, opacity 0.15s ease;
  }
  .sk__send:hover {
    background: var(--accent-hover);
  }
  .sk__send:disabled {
    opacity: 0.5;
    cursor: default;
  }
  .sk__note {
    margin-top: var(--space-3);
    font-size: 0.78125rem;
    line-height: 1.4;
    color: var(--subtle);
    text-align: center;
  }
  .sk__note a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .sk__note a:hover {
    color: var(--foreground);
  }

  /* Panel runs a touch tighter than the full page. */
  .sk[data-variant="panel"] .sk-bubble,
  .sk[data-variant="panel"] .sk-msg--user {
    font-size: 1rem;
  }
</style>

<!-- Client logic for every `.sk` surface (the /chatt/ page and the launcher
     panel both render this component). Imported for side effects — chat.ts
     self-initialises via `document.querySelectorAll(".sk").forEach(initChat)`.
     Astro bundles and dedupes this, so it loads once per page. -->
<script>
  import "./chat.ts";
</script>
