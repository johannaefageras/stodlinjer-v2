---
import ThemeToggle from "./ThemeToggle.astro";

// Shared sticky topbar for every page (homepage included). Brand + primary
// nav + theme toggle + chat CTA. Below 560px the text links collapse into a
// dropdown disclosure behind the burger so they stay reachable on phones.
const path = Astro.url.pathname;
const isHome = path === "/";
const isArticles = path.startsWith("/artiklar");
---

<header class="topbar">
  <div class="topbar__inner container--wide">
    <a class="brand" href="/">Stödlinjer</a>
    <div class="nav">
      <nav class="nav__links" id="primary-nav" aria-label="Huvudmeny">
        <a class="nav__link" href="/#stodlinjer" aria-current={isHome ? "page" : undefined}>Stödlinjer</a>
        <a class="nav__link" href="/artiklar/" aria-current={isArticles ? "page" : undefined}>Artiklar</a>
      </nav>
      <span class="nav__sep" aria-hidden="true"></span>
      <ThemeToggle />
      <a class="nav__cta" href="/chatt/">Fråga Stödkompassen</a>
      <button
        class="nav__burger"
        type="button"
        aria-controls="primary-nav"
        aria-expanded="false"
      >
        <span class="sr-only">Meny</span>
        <svg class="nav__burger-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg class="nav__burger-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    /* Sits flush below the sticky AcuteStrip when present (homepage); the
       variable defaults to 0 on pages without the strip. */
    top: var(--acute-strip-h, 0);
    z-index: 50;
    border-bottom: var(--hairline) solid var(--border);
    background: color-mix(in oklch, var(--background) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500; /* Book — holds the serif's contrast at this size */
    letter-spacing: -0.005em;
    color: var(--foreground);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: 0.9375rem;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .nav__link {
    position: relative;
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .nav__link:hover {
    color: var(--foreground);
  }
  .nav__link[aria-current="page"] {
    color: var(--foreground);
  }
  .nav__link[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -5px;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
  }
  /* Hairline divider between navigation and the utility controls / CTA. */
  .nav__sep {
    width: var(--hairline);
    height: 20px;
    background: var(--border);
  }
  .nav__cta {
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--accent-fg);
    font-size: 0.90625rem;
    font-weight: 500;
    transition: background 0.15s ease;
  }
  .nav__cta:hover {
    background: var(--accent-hover);
  }
  /* Mobile disclosure trigger — hidden until the layout gets tight. */
  .nav__burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--muted);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .nav__burger:hover {
    color: var(--foreground);
    border-color: var(--border-strong);
  }
  .nav__burger-close {
    display: none;
  }
  .nav__burger[aria-expanded="true"] .nav__burger-menu {
    display: none;
  }
  .nav__burger[aria-expanded="true"] .nav__burger-close {
    display: block;
  }

  /* On narrow screens, fold the text links into a dropdown panel behind the
     burger instead of dropping them entirely — they stay reachable. */
  @media (max-width: 560px) {
    .nav__sep {
      display: none;
    }
    .nav__burger {
      display: inline-flex;
    }
    .nav__links {
      position: absolute;
      top: calc(100% + var(--space-2));
      right: var(--space-6);
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-1);
      min-width: 200px;
      padding: var(--space-2);
      border: var(--hairline) solid var(--border);
      border-radius: var(--radius-lg);
      background: var(--surface);
      box-shadow: 0 14px 32px -14px color-mix(in oklch, var(--foreground) 40%, transparent);
      display: none;
    }
    .topbar[data-open] .nav__links {
      display: flex;
    }
    .nav__link {
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
    }
    .nav__link:hover {
      background: var(--hover);
    }
    .nav__link[aria-current="page"] {
      color: var(--accent-soft-fg);
      background: var(--accent-soft);
    }
    .nav__link[aria-current="page"]::after {
      display: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>(".topbar");
  const burger = header?.querySelector<HTMLButtonElement>(".nav__burger");
  if (header && burger) {
    const close = () => {
      header.removeAttribute("data-open");
      burger.setAttribute("aria-expanded", "false");
    };
    burger.addEventListener("click", () => {
      const open = header.toggleAttribute("data-open");
      burger.setAttribute("aria-expanded", String(open));
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
    document.addEventListener("click", (e) => {
      if (header.hasAttribute("data-open") && !header.contains(e.target as Node)) close();
    });
    header
      .querySelectorAll(".nav__link")
      .forEach((link) => link.addEventListener("click", close));
  }
</script>
