---
import CategoryIcon from "../CategoryIcon.astro";
import MIcon from "./MIcon.astro";

interface HoursRow {
  dayRange: string;
  time: string;
}
interface Props {
  name: string;
  shortDescription: string;
  categoryColor: string;
  categoryIcon: string;
  categoryId: string;
  categoryLabel: string;
  phone: string | null;
  telHref: string | null;
  primaryLabel: string;
  hoursDetail: HoursRow[];
  hoursClosed: string | null;
  href: string;
}
const {
  name,
  shortDescription,
  categoryColor,
  categoryIcon,
  categoryId,
  categoryLabel,
  phone,
  telHref,
  primaryLabel,
  hoursDetail,
  hoursClosed,
  href,
} = Astro.props;

// Placeholder category route — doesn't exist yet (same pattern as the
// homepage's /stodlinjer/<slug>/ links).
const catHref = `/kategorier/${categoryId}/`;
---

<article
  class="ce"
  style={`--c: var(--cat-${categoryColor}, var(--accent-soft)); --c-fg: var(--cat-${categoryColor}-fg, var(--accent-soft-fg));`}
>
  <div class="ce__head">
    <a class="ce__name" href={href}>{name}</a>
    <a class="ce__cat" href={catHref}>
      <span class="ce__caticon" aria-hidden="true">
        <CategoryIcon name={categoryIcon} size={14} />
      </span>
      <span class="ce__catlabel">{categoryLabel}</span>
      <span class="ce__catarrow" aria-hidden="true">
        <MIcon name="arrow" size={12} />
      </span>
    </a>
  </div>

  <p class="ce__desc">{shortDescription}</p>

  <div class="ce__foot">
    {
      phone && telHref ? (
        <a class="ce__phone" href={telHref}>
          <MIcon name="phone" size={15} />
          <span class="mono">{phone}</span>
        </a>
      ) : (
        <span class="ce__phone ce__phone--label">
          <MIcon name="phone" size={15} />
          <span>{primaryLabel}</span>
        </span>
      )
    }
    {
      hoursDetail.length > 0 && (
        <details class="ce__pop">
          <summary class="ce__summary">
            <MIcon name="clock" size={13} />
            <span>Öppettider</span>
            <span class="ce__chev">
              <MIcon name="chevron" size={13} />
            </span>
          </summary>
          <div class="ce__panel">
            {hoursDetail.map((row) => (
              <div class="ce__hrow">
                <span class="ce__day">{row.dayRange}</span>
                <span class="ce__time mono">{row.time}</span>
              </div>
            ))}
            {hoursClosed && (
              <div class="ce__hrow ce__hrow--off">
                <span class="ce__day">{hoursClosed}</span>
                <span class="ce__time">Stängt</span>
              </div>
            )}
          </div>
        </details>
      )
    }
  </div>
</article>

<style>
  .ce {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .ce:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }

  /* ── Header: serif title, category link beneath ─────────────── */
  .ce__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 7px;
  }
  .ce__name {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.22;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-decoration: none;
    text-wrap: balance;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  /* Stretched link: the title's overlay covers the whole card. */
  .ce__name::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  /* Category reads as a small link; sits above the stretched overlay. */
  .ce__cat {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--c-fg);
    text-decoration: none;
    font-size: 0.78125rem;
    font-weight: 500;
    letter-spacing: 0.005em;
  }
  .ce__caticon {
    display: flex;
    flex-shrink: 0;
  }
  .ce__catlabel {
    text-underline-offset: 2px;
  }
  .ce__cat:hover .ce__catlabel {
    text-decoration: underline;
  }
  .ce__catarrow {
    display: flex;
    opacity: 0;
    transform: translateX(-2px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }
  .ce__cat:hover .ce__catarrow {
    opacity: 0.7;
    transform: translateX(0);
  }

  .ce__desc {
    margin: 0;
    font-size: 0.84375rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer (phone + Öppettider popover) ────────────────────── */
  .ce__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  .ce__phone {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    white-space: nowrap;
    min-width: 0;
  }
  .ce__phone :global(.icon) {
    color: var(--c-fg);
    flex-shrink: 0;
  }
  .ce__phone .mono {
    font-size: 0.9375rem;
  }
  .ce__phone:hover .mono {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ce__phone--label {
    overflow: hidden;
  }
  .ce__phone--label span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ce__pop {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .ce__summary {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 9px;
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    color: var(--muted);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .ce__summary::-webkit-details-marker {
    display: none;
  }
  .ce__summary:hover {
    color: var(--foreground);
    border-color: var(--border-strong);
    background: var(--hover);
  }
  .ce__summary :global(.icon) {
    flex-shrink: 0;
  }
  .ce__chev {
    display: flex;
    transition: transform 0.18s ease;
  }
  .ce__pop[open] .ce__chev {
    transform: rotate(180deg);
  }
  .ce__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    width: max-content;
    min-width: 168px;
    padding: var(--space-2);
    border: var(--hairline) solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: 0 16px 40px -20px oklch(0 0 0 / 0.5);
  }
  .ce__hrow {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 3px 5px;
    font-size: 0.78125rem;
  }
  .ce__day {
    color: var(--muted);
  }
  .ce__time {
    color: var(--foreground);
    white-space: nowrap;
  }
  .ce__hrow--off .ce__day,
  .ce__hrow--off .ce__time {
    color: var(--subtle);
  }
</style>
