---
import CategoryIcon from "../CategoryIcon.astro";
import MIcon from "./MIcon.astro";

interface Props {
  name: string;
  shortDescription: string;
  categoryColor: string;
  categoryIcon: string;
  categoryLabel: string;
  phone: string | null;
  telHref: string | null;
  primaryLabel: string;
  hoursShort: string | null;
  href: string;
}
const {
  name,
  shortDescription,
  categoryColor,
  categoryIcon,
  categoryLabel,
  phone,
  telHref,
  primaryLabel,
  hoursShort,
  href,
} = Astro.props;
---

<article
  class="cc"
  style={`--c: var(--cat-${categoryColor}, var(--accent-soft)); --c-fg: var(--cat-${categoryColor}-fg, var(--accent-soft-fg));`}
>
  <span class="cc__cat">
    <span class="cc__caticon" aria-hidden="true">
      <CategoryIcon name={categoryIcon} size={13} />
    </span>
    {categoryLabel}
  </span>

  <a class="cc__name" href={href}>{name}</a>
  <p class="cc__desc">{shortDescription}</p>

  <div class="cc__foot">
    <span class="cc__contact">
      {
        phone && telHref ? (
          <a class="cc__phone" href={telHref}>
            <MIcon name="phone" size={14} />
            <span class="mono">{phone}</span>
          </a>
        ) : (
          <span class="cc__phone cc__phone--label">
            <MIcon name="phone" size={14} />
            <span>{primaryLabel}</span>
          </span>
        )
      }
      {
        hoursShort && (
          <Fragment>
            <span class="cc__sep" aria-hidden="true">·</span>
            <span class="cc__hours">{hoursShort}</span>
          </Fragment>
        )
      }
    </span>
    <span class="cc__arrow" aria-hidden="true">
      <MIcon name="arrow" size={15} />
    </span>
  </div>
</article>

<style>
  .cc {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    padding-left: calc(var(--space-4) + 6px);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  /* Colour lives in the spine — the only tint on the card. */
  .cc::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--c-fg);
    border-radius: var(--radius-card) 0 0 var(--radius-card);
  }
  .cc:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }

  .cc__cat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .cc__caticon {
    display: flex;
    color: var(--c-fg);
  }

  .cc__name {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-decoration: none;
    text-wrap: balance;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .cc__name::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }
  .cc__desc {
    margin: 0;
    font-size: 0.84375rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cc__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  .cc__contact {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-width: 0;
    font-size: 0.8125rem;
  }
  .cc__phone {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }
  .cc__phone :global(.icon) {
    color: var(--c-fg);
    flex-shrink: 0;
  }
  .cc__phone:hover .mono {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cc__phone--label span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cc__sep {
    color: var(--border-strong);
  }
  .cc__hours {
    color: var(--subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cc__arrow {
    display: flex;
    flex-shrink: 0;
    color: var(--subtle);
    transition:
      color 0.16s ease,
      transform 0.16s ease;
  }
  .cc:hover .cc__arrow {
    color: var(--foreground);
    transform: translate(2px, -2px);
  }
</style>
