---
import CategoryIcon from "../CategoryIcon.astro";
import MIcon from "./MIcon.astro";

interface Props {
  name: string;
  shortDescription: string;
  categoryColor: string;
  categoryIcon: string;
  categoryLabel: string;
  phone: string | null;
  telHref: string | null;
  primaryLabel: string;
  hoursShort: string | null;
  href: string;
}
const {
  name,
  shortDescription,
  categoryColor,
  categoryIcon,
  categoryLabel,
  phone,
  telHref,
  primaryLabel,
  hoursShort,
  href,
} = Astro.props;
---

<article
  class="ca"
  style={`--c: var(--cat-${categoryColor}, var(--accent-soft)); --c-fg: var(--cat-${categoryColor}-fg, var(--accent-soft-fg));`}
>
  <div class="ca__head">
    <span class="ca__box" aria-hidden="true">
      <CategoryIcon name={categoryIcon} size={20} />
    </span>
    <span class="ca__heads">
      <span class="ca__cat">{categoryLabel}</span>
      <a class="ca__name" href={href}>{name}</a>
    </span>
  </div>

  <p class="ca__desc">{shortDescription}</p>

  <div class="ca__foot">
    {
      phone && telHref ? (
        <a class="ca__phone" href={telHref}>
          <MIcon name="phone" size={15} />
          <span class="mono">{phone}</span>
        </a>
      ) : (
        <span class="ca__phone ca__phone--label">
          <MIcon name="phone" size={15} />
          <span>{primaryLabel}</span>
        </span>
      )
    }
    {
      hoursShort && (
        <span class="ca__hours">
          <MIcon name="clock" size={13} />
          <span>{hoursShort}</span>
        </span>
      )
    }
  </div>
</article>

<style>
  .ca {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .ca:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }

  .ca__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .ca__box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: calc(var(--radius-card) - 6px);
    background: var(--c);
    color: var(--c-fg);
  }
  .ca__heads {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .ca__cat {
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .ca__name {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-decoration: none;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  /* Stretched link: the name covers the whole card for the detail nav. */
  .ca__name::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  .ca__desc {
    margin: 0;
    font-size: 0.84375rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ca__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  /* Phone sits above the stretched link so tap-to-call stays clickable. */
  .ca__phone {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    white-space: nowrap;
    min-width: 0;
  }
  .ca__phone :global(.icon) {
    color: var(--c-fg);
    flex-shrink: 0;
  }
  .ca__phone .mono {
    font-size: 0.9375rem;
    letter-spacing: 0;
  }
  .ca__phone:hover .mono {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ca__phone--label {
    font-weight: 500;
    overflow: hidden;
  }
  .ca__phone--label span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ca__hours {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--subtle);
    white-space: nowrap;
  }
  .ca__hours :global(.icon) {
    flex-shrink: 0;
  }
</style>
