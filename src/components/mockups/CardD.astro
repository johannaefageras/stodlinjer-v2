---
import CategoryIcon from "../CategoryIcon.astro";
import MIcon from "./MIcon.astro";

interface HoursRow {
  dayRange: string;
  time: string;
}
interface Props {
  name: string;
  shortDescription: string;
  categoryColor: string;
  categoryIcon: string;
  categoryLabel: string;
  phone: string | null;
  telHref: string | null;
  primaryLabel: string;
  hoursDetail: HoursRow[];
  hoursClosed: string | null;
  href: string;
}
const {
  name,
  shortDescription,
  categoryColor,
  categoryIcon,
  categoryLabel,
  phone,
  telHref,
  primaryLabel,
  hoursDetail,
  hoursClosed,
  href,
} = Astro.props;
---

<article
  class="cd"
  style={`--c: var(--cat-${categoryColor}, var(--accent-soft)); --c-fg: var(--cat-${categoryColor}-fg, var(--accent-soft-fg));`}
>
  <div class="cd__head">
    <div class="cd__top">
      <span class="cd__box" aria-hidden="true">
        <CategoryIcon name={categoryIcon} size={20} />
      </span>
      <span class="cd__cat">{categoryLabel}</span>
    </div>
    <a class="cd__name" href={href}>{name}</a>
  </div>

  <p class="cd__desc">{shortDescription}</p>

  <div class="cd__foot">
    {
      phone && telHref ? (
        <a class="cd__phone" href={telHref}>
          <MIcon name="phone" size={15} />
          <span class="mono">{phone}</span>
        </a>
      ) : (
        <span class="cd__phone cd__phone--label">
          <MIcon name="phone" size={15} />
          <span>{primaryLabel}</span>
        </span>
      )
    }
    {
      hoursDetail.length > 0 && (
        <details class="cd__pop">
          <summary class="cd__summary">
            <MIcon name="clock" size={13} />
            <span>Öppettider</span>
            <span class="cd__chev"><MIcon name="chevron" size={13} /></span>
          </summary>
          <div class="cd__panel">
            {hoursDetail.map((row) => (
              <div class="cd__row">
                <span class="cd__day">{row.dayRange}</span>
                <span class="cd__time mono">{row.time}</span>
              </div>
            ))}
            {hoursClosed && (
              <div class="cd__row cd__row--off">
                <span class="cd__day">{hoursClosed}</span>
                <span class="cd__time">Stängt</span>
              </div>
            )}
          </div>
        </details>
      )
    }
  </div>
</article>

<style>
  .cd {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .cd:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }

  /* Eyebrow row (icon + category) stacked tight above a full-width name,
     so long titles get the whole card width instead of a narrow column. */
  .cd__head {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .cd__top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .cd__box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: calc(var(--radius-card) - 6px);
    background: var(--c);
    color: var(--c-fg);
  }
  .cd__cat {
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .cd__name {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 500;
    line-height: 1.22;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-decoration: none;
    /* Long titles: balance 2-line wraps, hyphenate (lang="sv"), and
       hard-break pathological single words rather than overflow. */
    text-wrap: balance;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .cd__name::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  .cd__desc {
    margin: 0;
    font-size: 0.84375rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cd__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  .cd__phone {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    white-space: nowrap;
    min-width: 0;
  }
  .cd__phone :global(.icon) {
    color: var(--c-fg);
    flex-shrink: 0;
  }
  .cd__phone .mono {
    font-size: 0.9375rem;
  }
  .cd__phone:hover .mono {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cd__phone--label {
    overflow: hidden;
  }
  .cd__phone--label span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Opening-hours popover. Native <details> = keyboard-accessible, no JS.
     Sits above the stretched link (z-index) so toggling never navigates. */
  .cd__pop {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .cd__summary {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 9px;
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    color: var(--muted);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .cd__summary::-webkit-details-marker {
    display: none;
  }
  .cd__summary:hover {
    color: var(--foreground);
    border-color: var(--border-strong);
    background: var(--hover);
  }
  .cd__summary :global(.icon) {
    flex-shrink: 0;
  }
  .cd__chev {
    display: flex;
    transition: transform 0.18s ease;
  }
  .cd__pop[open] .cd__chev {
    transform: rotate(180deg);
  }

  .cd__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    width: max-content;
    min-width: 168px;
    padding: var(--space-2);
    border: var(--hairline) solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: 0 16px 40px -20px oklch(0 0 0 / 0.5);
  }
  .cd__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 3px 5px;
    font-size: 0.78125rem;
  }
  .cd__day {
    color: var(--muted);
  }
  .cd__time {
    color: var(--foreground);
    white-space: nowrap;
  }
  .cd__row--off .cd__day,
  .cd__row--off .cd__time {
    color: var(--subtle);
  }
</style>
