---
import CategoryIcon from "../CategoryIcon.astro";
import MIcon from "./MIcon.astro";

interface HoursRow {
  dayRange: string;
  time: string;
}
interface Props {
  layout: "1" | "2" | "3";
  name: string;
  shortDescription: string;
  categoryColor: string;
  categoryIcon: string;
  categoryLabel: string;
  phone: string | null;
  telHref: string | null;
  primaryLabel: string;
  hoursDetail: HoursRow[];
  hoursClosed: string | null;
  href: string;
}
const {
  layout,
  name,
  shortDescription,
  categoryColor,
  categoryIcon,
  categoryLabel,
  phone,
  telHref,
  primaryLabel,
  hoursDetail,
  hoursClosed,
  href,
} = Astro.props;
---

<article
  class={`cdx cdx--l${layout}`}
  style={`--c: var(--cat-${categoryColor}, var(--accent-soft)); --c-fg: var(--cat-${categoryColor}-fg, var(--accent-soft-fg));`}
>
  {
    layout === "1" && (
      <div class="cdx__head">
        <span class="cdx__cat">{categoryLabel}</span>
        <div class="cdx__row">
          <span class="cdx__box" aria-hidden="true">
            <CategoryIcon name={categoryIcon} size={20} />
          </span>
          <a class="cdx__name" href={href}>
            {name}
          </a>
        </div>
      </div>
    )
  }
  {
    layout === "2" && (
      <div class="cdx__head">
        <span class="cdx__box" aria-hidden="true">
          <CategoryIcon name={categoryIcon} size={20} />
        </span>
        <span class="cdx__cat">{categoryLabel}</span>
        <a class="cdx__name" href={href}>
          {name}
        </a>
      </div>
    )
  }
  {
    layout === "3" && (
      <div class="cdx__head">
        <div class="cdx__row">
          <span class="cdx__box" aria-hidden="true">
            <CategoryIcon name={categoryIcon} size={20} />
          </span>
          <a class="cdx__name" href={href}>
            {name}
          </a>
        </div>
        <span class="cdx__cat cdx__cat--under">{categoryLabel}</span>
      </div>
    )
  }

  <p class="cdx__desc">{shortDescription}</p>

  <div class="cdx__foot">
    {
      phone && telHref ? (
        <a class="cdx__phone" href={telHref}>
          <MIcon name="phone" size={15} />
          <span class="mono">{phone}</span>
        </a>
      ) : (
        <span class="cdx__phone cdx__phone--label">
          <MIcon name="phone" size={15} />
          <span>{primaryLabel}</span>
        </span>
      )
    }
    {
      hoursDetail.length > 0 && (
        <details class="cdx__pop">
          <summary class="cdx__summary">
            <MIcon name="clock" size={13} />
            <span>Öppettider</span>
            <span class="cdx__chev">
              <MIcon name="chevron" size={13} />
            </span>
          </summary>
          <div class="cdx__panel">
            {hoursDetail.map((row) => (
              <div class="cdx__hrow">
                <span class="cdx__day">{row.dayRange}</span>
                <span class="cdx__time mono">{row.time}</span>
              </div>
            ))}
            {hoursClosed && (
              <div class="cdx__hrow cdx__hrow--off">
                <span class="cdx__day">{hoursClosed}</span>
                <span class="cdx__time">Stängt</span>
              </div>
            )}
          </div>
        </details>
      )
    }
  </div>
</article>

<style>
  .cdx {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .cdx:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }

  .cdx__box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: calc(var(--radius-card) - 6px);
    background: var(--c);
    color: var(--c-fg);
  }
  .cdx__cat {
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .cdx__name {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.22;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-decoration: none;
    text-wrap: balance;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .cdx__name::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  /* ── Layout 1: eyebrow on top, icon + title share a row ─────── */
  .cdx--l1 .cdx__head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cdx--l1 .cdx__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* ── Layout 2: icon badge alone, eyebrow + title stacked flush-left */
  .cdx--l2 .cdx__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .cdx--l2 .cdx__box {
    margin-bottom: 2px;
  }

  /* ── Layout 3: icon + title row, category as a quiet line under ── */
  .cdx--l3 .cdx__head {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .cdx--l3 .cdx__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .cdx--l3 .cdx__cat--under {
    color: var(--c-fg);
  }

  .cdx__desc {
    margin: 0;
    font-size: 0.84375rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cdx__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--border);
  }
  .cdx__phone {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    white-space: nowrap;
    min-width: 0;
  }
  .cdx__phone :global(.icon) {
    color: var(--c-fg);
    flex-shrink: 0;
  }
  .cdx__phone .mono {
    font-size: 0.9375rem;
  }
  .cdx__phone:hover .mono {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cdx__phone--label {
    overflow: hidden;
  }
  .cdx__phone--label span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cdx__pop {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .cdx__summary {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 9px;
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    color: var(--muted);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .cdx__summary::-webkit-details-marker {
    display: none;
  }
  .cdx__summary:hover {
    color: var(--foreground);
    border-color: var(--border-strong);
    background: var(--hover);
  }
  .cdx__summary :global(.icon) {
    flex-shrink: 0;
  }
  .cdx__chev {
    display: flex;
    transition: transform 0.18s ease;
  }
  .cdx__pop[open] .cdx__chev {
    transform: rotate(180deg);
  }
  .cdx__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    width: max-content;
    min-width: 168px;
    padding: var(--space-2);
    border: var(--hairline) solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: 0 16px 40px -20px oklch(0 0 0 / 0.5);
  }
  .cdx__hrow {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 3px 5px;
    font-size: 0.78125rem;
  }
  .cdx__day {
    color: var(--muted);
  }
  .cdx__time {
    color: var(--foreground);
    white-space: nowrap;
  }
  .cdx__hrow--off .cdx__day,
  .cdx__hrow--off .cdx__time {
    color: var(--subtle);
  }
</style>
