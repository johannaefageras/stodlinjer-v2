---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  readingTime?: string;
  /** Collection colour name; only `red` renders distinctly, rest = periwinkle. */
  color: string;
}

const { href, title, description, readingTime, color } = Astro.props;
---

<article
  class="acard"
  style={`--c: var(--cat-${color}, var(--accent-soft)); --c-fg: var(--cat-${color}-fg, var(--accent-soft-fg));`}
>
  <span class="acard__rule" aria-hidden="true"></span>
  <a class="acard__title" href={href}>{title}</a>
  <p class="acard__desc">{description}</p>
  {
    readingTime && (
      <span class="acard__foot mono">
        <Icon name="round-clock-face" size={14} />
        {readingTime}
      </span>
    )
  }
</article>

<style>
  .acard {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: var(--hairline) solid var(--border);
    border-radius: var(--radius-card);
    background: var(--surface);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .acard:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px -16px oklch(0 0 0 / 0.35);
  }
  /* A short tinted rule at the top — the collection's colour cue. */
  .acard__rule {
    width: 36px;
    height: 4px;
    border-radius: var(--radius-pill);
    background: var(--c-fg);
    opacity: 0.85;
  }
  .acard__title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--foreground);
    text-wrap: balance;
    overflow-wrap: break-word;
  }
  /* Stretched link — the whole card is clickable. */
  .acard__title::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }
  .acard__desc {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .acard__foot {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: var(--space-2);
    font-size: 0.8125rem;
    color: var(--subtle);
  }
  .acard__foot :global(.icon) {
    flex-shrink: 0;
  }
</style>
